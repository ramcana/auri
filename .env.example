# Auri environment configuration — copy to .env and edit as needed

# vLLM server (must bind to loopback; do not expose publicly without auth)
VLLM_HOST=127.0.0.1
VLLM_PORT=8000
VLLM_STARTUP_TIMEOUT=180

# Ollama OpenAI-compatible endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Maximum number of LoRA adapters loaded into vLLM simultaneously (LRU eviction)
MAX_LOADED_LORAS=4

# Log level: DEBUG, INFO, WARNING, ERROR
AURI_LOG_LEVEL=INFO
